<Window x:Class="CleanScope.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}"
        mc:Ignorable="d"
        Title="CleanScope" Height="760" Width="1180" MinHeight="560" MinWidth="900"
        Icon="pack://application:,,,/icon.ico"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#D6DEE8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1C2A3D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A5666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧栏导航 -->
        <Border Grid.Column="0" Background="#101826">
            <StackPanel Margin="18,24">
                <TextBlock Text="CleanScope" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="C 盘 AI 清理助手" Foreground="#8FA0B5" Margin="0,2,0,2"/>
                <TextBlock Text="删除仅移入回收站 · 可还原" Foreground="#5FC88F" FontSize="11" Margin="0,0,0,28"/>

                <Button Content="① 概览 / 扫描" Command="{Binding GoHomeCommand}" Style="{StaticResource NavBtn}"/>
                <Button Content="② 资源管理器" Command="{Binding GoExplorerCommand}" Style="{StaticResource NavBtn}"/>
                <Button Content="③ 空间地图" Command="{Binding GoMapCommand}" Style="{StaticResource NavBtn}"/>
                <Button Content="④ 文件清单" Command="{Binding GoListCommand}" Style="{StaticResource NavBtn}"/>
                <Button Content="⑤ 按软件" Command="{Binding GoBySoftwareCommand}" Style="{StaticResource NavBtn}"/>
                <Button Content="⑥ 报告 / 忽略名单" Command="{Binding GoReportCommand}" Style="{StaticResource NavBtn}"/>

                <Border Margin="0,28,0,0" Padding="10" CornerRadius="6" Background="#16202E">
                    <TextBlock Text="{Binding AiBadge}" Foreground="#8FA0B5" FontSize="11" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Card}" BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,0,1" Padding="24,14">
                <TextBlock Text="{Binding Title}" Style="{StaticResource H2}" Margin="0"/>
            </Border>

            <!-- 不再用外层 ScrollViewer 包裹: 否则给内部 ListView 无限高度, 关闭 UI 虚拟化导致卡顿。
                 各页自行管理滚动 (列表/空间地图自带滚动并虚拟化; 其余页内置 ScrollViewer)。 -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="24,18"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
