<Window x:Class="CleanScope.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
        xmlns:ctrl="clr-namespace:CleanScope.App.Wpf.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}"
        mc:Ignorable="d"
        Title="CleanScope" Height="760" Width="1180" MinHeight="560" MinWidth="900"
        Icon="pack://application:,,,/icon.ico"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource Bg}"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- B: 全局快捷键 — Esc 返回 (AI设置/详情) · F5 重扫上次目标 (Ctrl+F 聚焦搜索见 PreviewKeyDown) -->
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding BackCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RescanCommand}"/>
    </Window.InputBindings>

    <!-- 全局文字默认色 = Ink (随主题): 未显式设 Foreground 的文本 (树节点名/大小/Expander 头) 借继承取色,
         避免暗色下回退到框架默认黑字而看不清; 带样式的文本与按钮自设前景, 优先级更高不受影响。 -->
    <Border x:Name="RootBorder" Background="{DynamicResource Bg}" TextElement.Foreground="{DynamicResource Ink}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 自绘标题栏 (品牌 + 安全锚 + AI 设置 + 窗口按钮) ===== -->
            <Border Grid.Row="0" Background="{DynamicResource Card}" BorderBrush="{DynamicResource Line}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False">
                    <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="7" Margin="16,0,0,0"
                            Background="{DynamicResource Accent}" VerticalAlignment="Center">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock DockPanel.Dock="Left" Text="CleanScope" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource Ink}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <!-- 标题栏只留品牌 + 窗口控制; 安全承诺移到首页空状态, AI 状态瘦成图标(评审问题#1: 顶部减负) -->

                    <!-- 窗口按钮 (right→left: 关闭/最大化/最小化) -->
                    <Button x:Name="CloseBtn" DockPanel.Dock="Right" Style="{StaticResource WinClose}"
                            Content="&#xE8BB;" Click="CloseBtn_Click" AutomationProperties.Name="关闭" ToolTip="关闭"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MaxBtn" DockPanel.Dock="Right" Style="{StaticResource WinBtn}"
                            Content="&#xE922;" Click="MaxBtn_Click" AutomationProperties.Name="最大化或还原" ToolTip="最大化 / 还原"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MinBtn" DockPanel.Dock="Right" Style="{StaticResource WinBtn}"
                            Content="&#xE921;" Click="MinBtn_Click" AutomationProperties.Name="最小化" ToolTip="最小化"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <!-- E: 主题切换 (浅↔深); 图标提示将切换到的模式 -->
                    <Button x:Name="ThemeBtn" DockPanel.Dock="Right" Style="{StaticResource WinBtn}" Width="40" Margin="0,0,6,0"
                            Click="ThemeBtn_Click" ToolTip="切换深色 / 浅色主题"
                            AutomationProperties.Name="切换深色或浅色主题"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path x:Name="ThemeIcon" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Muted}"
                              Width="16" Height="16"/>
                    </Button>

                    <!-- AI 状态: 瘦成 点+AI+齿轮 (二级信息), 完整文案进 tooltip; 仍可点进设置, 保留发现性 -->
                    <Button DockPanel.Dock="Right" Style="{StaticResource AiPill}" Margin="0,0,10,0"
                            ToolTip="{Binding AiBadge}" AutomationProperties.Name="AI 设置"
                            Command="{Binding GoAiSettingsCommand}" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding AiEnabled, Converter={StaticResource AiDotBrush}}"/>
                            <TextBlock Text="AI" FontSize="12.5" VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                       Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Muted}"/>
                        </StackPanel>
                    </Button>
                </DockPanel>
            </Border>

            <!-- ===== 视图切换 = 原生 pivot (扁平 + 底线指示, 非浮起药丸; 仅扫描后出现) =====
                 评审 #2 左对齐贴合阅读流; #6 分隔线表达层级 (主: 概览/可清理清单 | 次: 三种镜头) -->
            <Border Grid.Row="1" Padding="24,2,24,0" Background="{DynamicResource Card}"
                    BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1"
                    Visibility="{Binding ShowResultsBar, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Tag="home" Content="概览" Command="{Binding GoHomeCommand}" Style="{StaticResource SegItem}" Margin="0,0,22,0"/>
                    <Button Tag="explorer" Content="目录浏览" Command="{Binding GoExplorerCommand}" Style="{StaticResource SegItem}" Margin="0,0,16,0"/>
                    <Border Width="1" Background="{DynamicResource Line}" Margin="0,9,18,9"/>
                    <Button Tag="map" Content="空间地图" Command="{Binding GoMapCommand}" Style="{StaticResource SegItem}" Margin="0,0,22,0"/>
                    <Button Tag="software" Content="按软件" Command="{Binding GoBySoftwareCommand}" Style="{StaticResource SegItem}" Margin="0,0,22,0"/>
                    <Button Tag="report" Content="报告" Command="{Binding GoReportCommand}" Style="{StaticResource SegItem}"/>
                </StackPanel>
            </Border>

            <!-- ===== 内容区 (满宽, 结果即主角); FocusVisualStyle 置空 = 点击内容区不再出现虚线焦点框 ===== -->
            <ContentControl Grid.Row="2" Content="{Binding CurrentView}" Margin="24,16,24,18"
                            FocusVisualStyle="{x:Null}"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

            <!-- 全局 Toast 反馈层 -->
            <ctrl:ToastHost Grid.Row="2" Panel.ZIndex="100"/>
        </Grid>
    </Border>
</Window>
