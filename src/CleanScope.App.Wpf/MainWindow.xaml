<Window x:Class="CleanScope.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
        xmlns:ctrl="clr-namespace:CleanScope.App.Wpf.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}"
        mc:Ignorable="d"
        Title="CleanScope" Height="760" Width="1180" MinHeight="560" MinWidth="900"
        Icon="pack://application:,,,/icon.ico"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource Card}"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="{StaticResource Card}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 自绘标题栏 (品牌 + 安全锚 + 窗口按钮) ===== -->
            <Border Grid.Row="0" Background="{StaticResource Card}" BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False">
                    <!-- 品牌 -->
                    <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="7" Margin="16,0,0,0"
                            Background="{StaticResource Accent}" VerticalAlignment="Center">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock DockPanel.Dock="Left" Text="CleanScope" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Ink}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Border DockPanel.Dock="Left" Style="{StaticResource Chip}" Background="{StaticResource CleanSoft}" Margin="12,0,0,0">
                        <TextBlock Text="🛡 只读分析 · 删除可还原" FontSize="12" Foreground="{StaticResource Clean}"/>
                    </Border>

                    <!-- 窗口按钮 -->
                    <Button x:Name="CloseBtn" DockPanel.Dock="Right" Style="{StaticResource WinClose}"
                            Content="&#xE8BB;" Click="CloseBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MaxBtn" DockPanel.Dock="Right" Style="{StaticResource WinBtn}"
                            Content="&#xE922;" Click="MaxBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MinBtn" DockPanel.Dock="Right" Style="{StaticResource WinBtn}"
                            Content="&#xE921;" Click="MinBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </DockPanel>
            </Border>

            <!-- ===== 主体: 侧栏 + 内容 ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="216"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 浅色一体导航 -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}" BorderBrush="{StaticResource Line}"
                        BorderThickness="0,0,1,0">
                    <DockPanel Margin="14,16,14,16">
                        <!-- 底部: 设置 + AI 状态 -->
                        <StackPanel DockPanel.Dock="Bottom">
                            <Button Tag="ai" Command="{Binding GoAiSettingsCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Width="26" VerticalAlignment="Center"/>
                                    <TextBlock Text="AI 设置" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Border Background="{StaticResource Subtle}" CornerRadius="8" Padding="12,9" Margin="0,10,0,0">
                                <TextBlock Text="{Binding AiBadge}" Foreground="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <!-- 主导航 -->
                        <StackPanel DockPanel.Dock="Top">
                            <Button Tag="home" Command="{Binding GoHomeCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Width="26" VerticalAlignment="Center"/>
                                    <TextBlock Text="概览 / 扫描" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="explorer" Command="{Binding GoExplorerCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Width="26" VerticalAlignment="Center"/>
                                    <TextBlock Text="可清理清单" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="map" Command="{Binding GoMapCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Width="26" VerticalAlignment="Center"/>
                                    <TextBlock Text="空间地图" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="software" Command="{Binding GoBySoftwareCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Width="26" VerticalAlignment="Center"/>
                                    <TextBlock Text="按软件占用" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="report" Command="{Binding GoReportCommand}" Style="{StaticResource NavItem}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Width="26" VerticalAlignment="Center"/>
                                    <TextBlock Text="报告 / 忽略" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 内容区 -->
                <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="24,18"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
            </Grid>

            <!-- 全局 Toast 反馈层 -->
            <ctrl:ToastHost Grid.Row="1" Panel.ZIndex="100"/>
        </Grid>
    </Border>
</Window>
