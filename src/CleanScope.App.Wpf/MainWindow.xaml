<Window x:Class="CleanScope.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
        xmlns:ctrl="clr-namespace:CleanScope.App.Wpf.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}"
        mc:Ignorable="d"
        Title="CleanScope" Height="760" Width="1180" MinHeight="560" MinWidth="900"
        Icon="pack://application:,,,/icon.ico"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 自绘标题栏 (品牌 + 安全锚 + AI 设置 + 窗口按钮) ===== -->
            <Border Grid.Row="0" Background="{StaticResource Card}" BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False">
                    <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="7" Margin="16,0,0,0"
                            Background="{StaticResource Accent}" VerticalAlignment="Center">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock DockPanel.Dock="Left" Text="CleanScope" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Ink}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <!-- #8: 安全承诺降为安静的内联文字 (保留信任锚, 不再用填色 chip 占据黄金区域) -->
                    <TextBlock DockPanel.Dock="Left" Text="🛡 只读分析 · 删除可还原" FontSize="12"
                               Foreground="{StaticResource Faint}" VerticalAlignment="Center" Margin="14,1,0,0"/>

                    <!-- 窗口按钮 (right→left: 关闭/最大化/最小化) -->
                    <Button x:Name="CloseBtn" DockPanel.Dock="Right" Style="{StaticResource WinClose}"
                            Content="&#xE8BB;" Click="CloseBtn_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MaxBtn" DockPanel.Dock="Right" Style="{StaticResource WinBtn}"
                            Content="&#xE922;" Click="MaxBtn_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MinBtn" DockPanel.Dock="Right" Style="{StaticResource WinBtn}"
                            Content="&#xE921;" Click="MinBtn_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <!-- #3/#4: AI 不再是隐藏的小齿轮 —— 标题栏常驻"带标签"的可点状态胶囊, 让用户始终知道 AI 状态、一眼可进配置 -->
                    <Button DockPanel.Dock="Right" Style="{StaticResource AiPill}" Margin="0,0,10,0"
                            ToolTip="AI 状态 · 点击进入设置 / 调脱敏档位"
                            Command="{Binding GoAiSettingsCommand}" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center"
                                     Fill="{Binding AiEnabled, Converter={StaticResource AiDotBrush}}"/>
                            <TextBlock Text="{Binding AiBadge}" FontSize="12.5" VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                       Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                        </StackPanel>
                    </Button>
                </DockPanel>
            </Border>

            <!-- ===== 结果内"视图切换"分段控件 (仅扫描后出现; 把镜头切换收进结果工作区) =====
                 #2 左对齐贴合 F 型阅读流; #6 用分隔线表达层级 (主: 概览/可清理清单 | 次: 三种镜头) -->
            <Border Grid.Row="1" Padding="24,14,24,0"
                    Visibility="{Binding ShowResultsBar, Converter={StaticResource BoolToVis}}">
                <Border Background="{StaticResource Subtle}" CornerRadius="10" Padding="3"
                        HorizontalAlignment="Left" BorderBrush="{StaticResource Line}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button Tag="home" Content="概览" Command="{Binding GoHomeCommand}" Style="{StaticResource SegItem}"/>
                        <Button Tag="explorer" Content="可清理清单" Command="{Binding GoExplorerCommand}" Style="{StaticResource SegItem}"/>
                        <Border Width="1" Background="{StaticResource Line}" Margin="5,7"/>
                        <Button Tag="map" Content="空间地图" Command="{Binding GoMapCommand}" Style="{StaticResource SegItem}"/>
                        <Button Tag="software" Content="按软件" Command="{Binding GoBySoftwareCommand}" Style="{StaticResource SegItem}"/>
                        <Button Tag="report" Content="报告" Command="{Binding GoReportCommand}" Style="{StaticResource SegItem}"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ===== 内容区 (满宽, 结果即主角) ===== -->
            <ContentControl Grid.Row="2" Content="{Binding CurrentView}" Margin="24,16,24,18"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

            <!-- 全局 Toast 反馈层 -->
            <ctrl:ToastHost Grid.Row="2" Panel.ZIndex="100"/>
        </Grid>
    </Border>
</Window>
