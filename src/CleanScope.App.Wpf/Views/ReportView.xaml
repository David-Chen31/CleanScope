<UserControl x:Class="CleanScope.App.Wpf.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:ReportViewModel}"
             mc:Ignorable="d" d:DesignWidth="860">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>

        <!-- F3: 回收历史 / 还原 (跨会话持久; 强化"删除可还原") -->
        <Border Style="{StaticResource Cards}">
            <StackPanel>
                <Grid>
                    <TextBlock Text="回收历史 · 随时可还原" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Command="{Binding OpenRecycleBinCommand}" Style="{StaticResource Outline}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconRestore}" Style="{StaticResource IconStroke}" Stroke="{StaticResource Ink}"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="打开回收站还原" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Text="{Binding HistoryStatus}" Style="{StaticResource Sub}" Margin="0,2,0,8" TextWrapping="Wrap"/>

                <ItemsControl ItemsSource="{Binding RecycleHistory}"
                              Visibility="{Binding HasRecycleHistory, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource Ink}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Background="{StaticResource CleanSoft}" CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                    Visibility="{Binding Recoverable, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="可还原" FontSize="11" Foreground="{StaticResource Clean}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Path}" Foreground="{StaticResource Muted}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding When}" Foreground="{StaticResource Faint}"
                                               FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 可清理类别聚合 (S3) -->
        <Border Style="{StaticResource Cards}"
                Visibility="{Binding HasCategories, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="可清理类别（按类别聚合，A/B）" Style="{StaticResource H2}"/>
                <TextBlock Style="{StaticResource Sub}" Margin="0,0,0,8">
                    <Run Text="预计可回收（去重，仍建议确认）："/><Run Text="{Binding ReclaimableTotal, Mode=OneWay}" FontWeight="Bold" Foreground="#1E7E34"/>
                    <Run Text="　— 仅给出可回收空间与官方清理方式，绝不自动删除。"/>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding CleanupCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Foreground="{StaticResource Muted}" FontSize="11">
                                            <Run Text="{Binding ItemCount, Mode=OneWay}"/><Run Text=" 项 · "/><Run Text="{Binding RiskText, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding ReclaimableText}" FontWeight="Bold"
                                               Foreground="#1E7E34" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RecommendedAction}" TextWrapping="Wrap"
                                               Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 报告导出 -->
        <Border Style="{StaticResource Cards}">
            <StackPanel>
                <TextBlock Text="导出 Markdown 报告" Style="{StaticResource H2}"/>
                <TextBlock Text="报告含扫描元信息、风险统计、按软件占用、可清理类别、占用大头与分级明细；删除决策由你做出，应用内删除仅移入回收站（可还原）。文件名以 .csv 结尾则导出 CSV（便于 Excel 透视），否则导出 Markdown。"
                           Style="{StaticResource Sub}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ExportPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="8,6"/>
                    <Button Grid.Column="1" Content="导出" Command="{Binding ExportCommand}"
                            Style="{StaticResource Primary}" Margin="10,0,0,0" MinWidth="96"/>
                </Grid>
                <TextBlock Text="{Binding ExportStatus}" Style="{StaticResource Sub}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- 忽略名单 -->
        <Border Style="{StaticResource Cards}">
            <StackPanel>
                <TextBlock Text="忽略名单（全局，跨扫描生效；仅本地存储）" Style="{StaticResource H2}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewIgnorePath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="8,6"
                             ToolTip="要忽略的完整路径"/>
                    <TextBox Grid.Column="1" Text="{Binding NewIgnoreReason, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="8,6" Margin="8,0"
                             ToolTip="原因（可选）"/>
                    <Button Grid.Column="2" Content="添加" Command="{Binding AddIgnoreCommand}"
                            Style="{StaticResource Ghost}" MinWidth="72"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Ignores}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding PathOrPattern}" Foreground="{StaticResource Ink}" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="{StaticResource Muted}" FontSize="11">
                                            <Run Text="{Binding MatchType, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding CreatedAt, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Reason, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="移除" MinWidth="64"
                                            Style="{StaticResource Ghost}"
                                            Command="{Binding DataContext.RemoveIgnoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding IgnoreStatus}" Style="{StaticResource Sub}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
