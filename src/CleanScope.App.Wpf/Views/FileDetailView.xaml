<UserControl x:Class="CleanScope.App.Wpf.Views.FileDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:views="clr-namespace:CleanScope.App.Wpf.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:FileDetailViewModel}"
             mc:Ignorable="d" d:DesignWidth="860">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>
        <Button Command="{Binding BackCommand}" Style="{StaticResource Outline}"
                HorizontalAlignment="Left" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconBackArrow}" Stroke="{DynamicResource Ink}" StrokeThickness="1.8"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      Width="20" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0"/>
                <TextBlock Text="返回" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <StackPanel DataContext="{Binding Row}">

            <!-- 标题 + 风险 -->
            <Border Style="{StaticResource Cards}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{Binding Bucket, Converter={StaticResource BucketToBrush}}"
                                CornerRadius="4" Padding="10,3" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BucketLabel}" FontWeight="Bold" Foreground="#222"/>
                        </Border>
                        <Border Background="{Binding RiskLevel, Converter={StaticResource RiskToBrush}}"
                                CornerRadius="4" Padding="8,3" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding RiskMeaning}" FontWeight="SemiBold" Foreground="#222"/>
                        </Border>
                        <TextBlock Text="{Binding SizeText}" FontSize="16" FontWeight="Bold" Margin="14,0,0,0"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Ink}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" Margin="0,10,0,2"/>
                    <TextBlock Text="{Binding Path}" Style="{StaticResource Sub}" TextWrapping="Wrap"/>

                    <!-- 高风险提示: D/E 强烈建议保留; 如确需清理, 下方「移入回收站」会要求二次强确认且仅进回收站(可还原) -->
                    <Border Margin="0,12,0,0" Padding="12" CornerRadius="6" Background="{DynamicResource CriticalSoft}"
                            Visibility="{Binding IsHighRisk, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{DynamicResource Critical}" VerticalAlignment="Top" Margin="0,3,8,0"/>
                            <TextBlock Foreground="{DynamicResource Critical}" TextWrapping="Wrap"
                                       Text="该项为高风险（D/E）：可能是系统/应用关键文件或无法判断来源，强烈建议保留。如确认是你自己的数据、确需清理，下方「移入回收站」会要求二次强确认，且只移入回收站、随时可还原。"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 属性 -->
            <Border Style="{StaticResource Cards}">
                <StackPanel>
                    <TextBlock Text="属性" Style="{StaticResource H2}"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,2"><TextBlock Text="类型" Style="{StaticResource Sub}"/><TextBlock Text="{Binding NodeType}"/></StackPanel>
                        <StackPanel Margin="0,2"><TextBlock Text="扩展名" Style="{StaticResource Sub}"/><TextBlock Text="{Binding Extension}"/></StackPanel>
                        <StackPanel Margin="0,2"><TextBlock Text="产品 / 公司" Style="{StaticResource Sub}"/><TextBlock Text="{Binding ProductName}"/></StackPanel>
                        <StackPanel Margin="0,2"><TextBlock Text="签名者" Style="{StaticResource Sub}"/><TextBlock Text="{Binding Signer}"/></StackPanel>
                        <StackPanel Margin="0,2"><TextBlock Text="最后修改" Style="{StaticResource Sub}"/><TextBlock Text="{Binding Mtime}"/></StackPanel>
                        <StackPanel Margin="0,2"><TextBlock Text="占用进程" Style="{StaticResource Sub}"/><TextBlock Text="{Binding OccupyingProcess}"/></StackPanel>
                    </UniformGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding IsReparsePoint, Converter={StaticResource BoolToVis}}">
                        <Path Data="{StaticResource IconWarn}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Warn}"
                              Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Top"/>
                        <TextBlock Foreground="{DynamicResource Warn}" TextWrapping="Wrap"
                                   Text="此项为符号链接 / 联接点；风险判定基于解析后的真实路径。"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 风险评估 -->
            <Border Style="{StaticResource Cards}">
                <StackPanel>
                    <TextBlock Text="风险评估（规则/风险引擎权威，AI 不可降低）" Style="{StaticResource H2}"/>
                    <TextBlock Text="{Binding RiskMeaning}" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
                    <ItemsControl ItemsSource="{Binding RiskFactors}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource Sub}" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 证据链: 事实 vs AI 推测, 视觉区分 (安全§9) -->
            <Border Style="{StaticResource Cards}">
                <StackPanel>
                    <TextBlock Text="证据链" Style="{StaticResource H2}"/>
                    <TextBlock Text="事实证据（可驱动权威结论）" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="0,4,0,4"/>
                    <ItemsControl ItemsSource="{Binding FactEvidences}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding IsFact, Converter={StaticResource FactToBrush}}"
                                        CornerRadius="6" Padding="10,7" Margin="0,3">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{DynamicResource Accent}" CornerRadius="3" Padding="5,1">
                                                <TextBlock Text="{Binding Badge}" Foreground="White" FontSize="11"/>
                                            </Border>
                                            <TextBlock Text="{Binding Kind}" Margin="8,0,0,0" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Ink}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Margin="0,3,0,0"
                                                   Foreground="{DynamicResource Ink}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="AI 推测（仅供解释参考，不影响风险判定）" Foreground="{DynamicResource Warn}" FontWeight="SemiBold"
                               Margin="0,10,0,4"
                               Visibility="{Binding HasInferenceEvidence, Converter={StaticResource BoolToVis}}"/>
                    <ItemsControl ItemsSource="{Binding InferenceEvidences}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding IsFact, Converter={StaticResource FactToBrush}}"
                                        CornerRadius="6" Padding="10,7" Margin="0,3">
                                    <StackPanel>
                                        <Border Background="{DynamicResource Warn}" CornerRadius="3" Padding="5,1" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Badge}" Foreground="White" FontSize="11"/>
                                        </Border>
                                        <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Margin="0,3,0,0"
                                                   Foreground="{DynamicResource Ink}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 归因候选 -->
            <Border Style="{StaticResource Cards}"
                    Visibility="{Binding HasAttributions, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="可能归属（候选 + 置信度，非唯一答案）" Style="{StaticResource H2}"/>
                    <ItemsControl ItemsSource="{Binding Attributions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="{Binding DisplayText}" Width="220" Foreground="{DynamicResource Ink}"/>
                                    <TextBlock Text="{Binding ConfidenceText}" Foreground="{DynamicResource Muted}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- AI 解释 (S6: 详情页按需生成; 仅 Validated 才展示, 绑定详情 VM) -->
        <Border Style="{StaticResource Cards}"
                Visibility="{Binding HasAi, Converter={StaticResource BoolToVis}}">
            <StackPanel DataContext="{Binding Ai}">
                <TextBlock Text="AI 解释" Style="{StaticResource H2}"/>
                <TextBlock Text="{Binding SourceLabel}" Foreground="{DynamicResource Muted}" FontSize="11" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding WhatIsIt}" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
                <TextBlock Text="{Binding UserFriendlyExplanation}" Style="{StaticResource Sub}" Margin="0,4,0,6"/>
                <ItemsControl ItemsSource="{Binding Reasoning}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource Sub}" Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 按需 AI 解释入口: 不自动出云, 用户点了才请求 (省 token); 未配置 AI / 已解释 / 系统关键时不显示 -->
        <Button Command="{Binding ExplainCommand}" Style="{StaticResource Ghost}"
                HorizontalAlignment="Left" Margin="0,0,0,8"
                Visibility="{Binding CanExplain, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconAi}" Style="{StaticResource IconFill}" Fill="{DynamicResource Accent}"
                      Width="13" Height="13" Margin="0,0,6,0"/>
                <TextBlock Text="用 AI 解释这一项（脱敏后请求，可选）" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- AI 状态 (生成中 / 不可用; 无解释卡时显示); 生成中显示转圈 (问题#2) -->
        <StackPanel Orientation="Horizontal" Margin="2,-4,0,8" VerticalAlignment="Center"
                    Visibility="{Binding AiStatus, Converter={StaticResource NotEmptyToVis}}">
            <views:Spinner Diameter="13" VerticalAlignment="Center"
                           Visibility="{Binding IsExplaining, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding AiStatus}" Style="{StaticResource Sub}" Margin="6,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 安全闸门判定 + 辅助操作 (无删除入口) -->
        <Border Style="{StaticResource Cards}">
            <StackPanel>
                <TextBlock Text="操作" Style="{StaticResource H2}"/>
                <Border Padding="10" CornerRadius="6" Background="{DynamicResource Subtle}" Margin="0,0,0,10">
                    <TextBlock Text="{Binding GuardVerdict}" Foreground="{DynamicResource Ink}" TextWrapping="Wrap"/>
                </Border>
                <!-- S-E 删除入口: 仅"可清理"(A/B) 项显示, 移入回收站可还原; 经两步确认+闸门复核+审计。 -->
                <!-- S-D 推荐动作: 命令型→运行/复制官方命令; 安装目录→卸载程序; 通用→定位/复制路径/忽略 -->
                <WrapPanel>
                    <Button Command="{Binding MoveToRecycleBinCommand}" Style="{StaticResource Primary}"
                            Margin="0,0,8,8" Visibility="{Binding Row.CanAttemptRecycle, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconTrash}" Style="{StaticResource IconStroke}" Stroke="White"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="移入回收站（可还原）" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RunCommandCommand}" Style="{StaticResource Primary}"
                            Margin="0,0,8,8" Visibility="{Binding Row.HasRunCommand, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlay}" Style="{StaticResource IconFill}" Fill="White"
                                  Width="13" Height="13" Margin="0,0,6,0"/>
                            <TextBlock Text="运行官方清理命令" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="复制清理命令" Command="{Binding CopyCommandCommand}" Style="{StaticResource Ghost}"
                            Margin="0,0,8,8" Visibility="{Binding Row.HasRunCommand, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="打开卸载程序" Command="{Binding UninstallCommand}" Style="{StaticResource Ghost}"
                            Margin="0,0,8,8" Visibility="{Binding Row.HasUninstall, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="在资源管理器中定位" Command="{Binding OpenFolderCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,8"/>
                    <Button Content="复制路径" Command="{Binding CopyPathCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,8"/>
                    <Button Content="加入忽略名单" Command="{Binding AddIgnoreCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,8"/>
                </WrapPanel>
                <TextBlock Text="{Binding ActionStatus}" Style="{StaticResource Sub}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
