<Window x:Class="CleanScope.App.Wpf.Views.SpaceWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance vm:SpaceWizardViewModel}" mc:Ignorable="d"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height"
        Width="560" WindowStartupLocation="CenterOwner" FontFamily="Segoe UI, Microsoft YaHei UI">

    <!-- P2: 引导式"腾出空间"向导 (小白友好): 三步把"安全瘦身"讲清并一键完成 -->
    <Border Background="{DynamicResource Card}" CornerRadius="14" Effect="{StaticResource PopShadow}" Margin="16">
        <StackPanel>
            <!-- 顶部带 (可拖动) -->
            <Border CornerRadius="14,14,0,0" Background="{DynamicResource AccentSoft}" Padding="24,18"
                    MouseLeftButtonDown="Header_Drag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="腾出空间向导" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource Ink}"/>
                        <TextBlock Text="一步步带你安全瘦身，全程只进回收站、可撤销。" FontSize="12.5"
                                   Foreground="{DynamicResource Muted}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource Chip}" Background="{DynamicResource Card}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StepText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Margin="24,18,24,8" MinHeight="200">
                <!-- ① 可放心清理 -->
                <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="① 这些可以放心清理" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource Ink}"/>
                    <TextBlock Text="CleanScope 已用确定性规则判好：下面这些是“可放心清理(A/B)”的项，删除只进回收站、可随时还原。"
                               Style="{StaticResource Sub}" Margin="0,4,0,12"/>
                    <Border Background="{DynamicResource CleanSoft}" CornerRadius="10" Padding="18,16"
                            Visibility="{Binding HasCleanable, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource Clean}">
                                <Run Text="约 "/><Run Text="{Binding ReclaimText, Mode=OneWay}" FontSize="26" FontWeight="Bold"/><Run Text="  可清理"/>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource Muted}" FontSize="12.5" Margin="0,2,0,12">
                                <Run Text="共 "/><Run Text="{Binding CleanCountText, Mode=OneWay}"/><Run Text=" · 一键全部移入回收站，可撤销"/>
                            </TextBlock>
                            <Button Command="{Binding OneClickCommand}" Style="{StaticResource Primary}" HorizontalAlignment="Left"
                                    Padding="20,11" FontSize="14.5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconTrash}" Style="{StaticResource IconStroke}" Stroke="White"
                                          Width="15" Height="15" Margin="0,0,7,0"/>
                                    <TextBlock Text="一键清理可放心清理项" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="本次没有发现可放心清理的项。可直接进入下一步看看其它腾空间的办法。"
                               Style="{StaticResource Sub}" Margin="0,2,0,0"
                               Visibility="{Binding HasCleanable, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                </StackPanel>

                <!-- ② 最占地但不能删 -->
                <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="② 最占地、但不能删的" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource Ink}"/>
                    <TextBlock Text="有些大目录是软件本体或你的资料，删不得。但可以“迁移到其他盘”——在原位留一个联接，软件照常用，又省下 C 盘空间。"
                               Style="{StaticResource Sub}" Margin="0,4,0,12"/>
                    <Border Background="{DynamicResource Subtle}" CornerRadius="10" Padding="16"
                            Visibility="{Binding HasBiggestKeep, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock>
                                <Run Text="最占地的一项：" Foreground="{DynamicResource Muted}"/>
                                <Run Text="{Binding KeepName, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource Ink}"/>
                                <Run Text="  ·  " Foreground="{DynamicResource Muted}"/>
                                <Run Text="{Binding KeepSize, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource Personal}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding KeepPath}" Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis" Margin="0,4,0,12"/>
                            <Button Command="{Binding GoListCommand}" Style="{StaticResource Ghost}" HorizontalAlignment="Left" Padding="14,8">
                                <TextBlock Text="去目录浏览 → 右键它选「迁移到其他盘」" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="没有发现明显可迁移的大目录，可直接进入下一步。" Style="{StaticResource Sub}"
                               Visibility="{Binding HasBiggestKeep, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                </StackPanel>

                <!-- ③ 官方手段 -->
                <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="③ 还能用官方手段再清一些" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource Ink}"/>
                    <TextBlock Text="这些是 Windows 自带的安全清理手段，点一下会先弹确认、无需命令行。"
                               Style="{StaticResource Sub}" Margin="0,4,0,12"/>
                    <ItemsControl ItemsSource="{Binding TopOfficial}"
                                  Visibility="{Binding HasOfficial, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Subtle}" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding SavingsText}" VerticalAlignment="Center" Margin="0,0,10,0"
                                                   FontWeight="Bold" Foreground="{DynamicResource Clean}"
                                                   Visibility="{Binding HasSavings, Converter={StaticResource BoolToVis}}"/>
                                        <Button Grid.Column="2" Content="{Binding RunButtonText}" VerticalAlignment="Center" MinWidth="100"
                                                Style="{StaticResource Ghost}"
                                                Command="{Binding DataContext.RunOfficialCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="本机暂未检测到适用的官方清理手段。" Style="{StaticResource Sub}"
                               Visibility="{Binding HasOfficial, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                </StackPanel>
            </Grid>

            <!-- 底部导航 -->
            <Grid Margin="24,6,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="上一步" Command="{Binding BackCommand}" Style="{StaticResource Ghost}" MinWidth="84"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="跳过" Click="Close_Click" Style="{StaticResource Ghost}" MinWidth="72" Margin="0,0,8,0"
                            Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                    <Button Content="下一步  →" Command="{Binding NextCommand}" Style="{StaticResource Primary}" MinWidth="110"
                            Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                    <Button Content="完成" Click="Close_Click" Style="{StaticResource Primary}" MinWidth="110"
                            Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</Window>
