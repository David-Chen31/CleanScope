<UserControl x:Class="CleanScope.App.Wpf.Views.AiSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:AiSettingsViewModel}"
             mc:Ignorable="d" d:DesignWidth="760">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Style="{StaticResource Cards}">
        <StackPanel>
            <!-- AI 设置页明确的返回出口; 用描边次级按钮, 比浅灰 Ghost 更显眼 (问题#3: 此前太浅太小) -->
            <Button Content="←  返回" Style="{StaticResource Outline}" HorizontalAlignment="Left" MinWidth="92" Margin="0,0,0,16"
                    Command="{Binding DataContext.GoBackFromAiCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <TextBlock Text="AI 设置" Style="{StaticResource H2}"/>
            <TextBlock Text="可选 · AI 仅在你点击 AI 功能时按需调用，不配置则全程本地。"
                       Style="{StaticResource Sub}" Margin="0,0,0,12"/>

            <TextBlock Text="{Binding CurrentState}" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,14"/>

            <TextBlock Text="Base URL（如 https://your-relay/v1）" Foreground="{StaticResource Ink}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Field}" Margin="0,0,0,12"/>

            <TextBlock Text="API Key" Foreground="{StaticResource Ink}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="KeyBox" Style="{StaticResource FieldPassword}" Margin="0,0,0,4" PasswordChanged="KeyBox_PasswordChanged"/>
            <TextBlock Text="🔒 本机 DPAPI 加密保存，绝不上传" Style="{StaticResource Caption}" Margin="2,0,0,12"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Button Content="🔍 检索模型" Command="{Binding ListModelsCommand}" Style="{StaticResource Ghost}" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}"
                          MinWidth="240" Padding="8,6" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <ToggleButton IsChecked="{Binding CloudEnabled}" Style="{StaticResource Toggle}" VerticalAlignment="Center"/>
                <TextBlock Text="启用 AI（脱敏后按需出云）" Foreground="{StaticResource Ink}" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 出云脱敏: 三档平铺单选, 醒目卡片 (问题#4: 让用户一眼看到能调档, 不致误以为 AI 识别力弱) -->
            <Border Background="#FFF7E6" BorderBrush="#F0C36D" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="🔧 出云脱敏档位（影响 AI 识别力 ←→ 隐私）" FontWeight="Bold" Foreground="#8A5A00" Margin="0,0,0,2"/>
                    <TextBlock Text="觉得 AI「认不出软件」？多半是脱敏太严。下面三档可随时切换，越往下识别越准、发送的路径信息越多。"
                               TextWrapping="Wrap" Style="{StaticResource Sub}" Margin="0,0,0,10"/>

                    <RadioButton GroupName="San" IsChecked="{Binding IsStrict}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" Content="严格 — 最隐私，识别力受限"/>
                    <TextBlock Text="{Binding StrictHint}" TextWrapping="Wrap" Style="{StaticResource Sub}" Margin="24,1,0,8"/>

                    <RadioButton GroupName="San" IsChecked="{Binding IsBalanced}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" Content="均衡 — 默认 · 推荐"/>
                    <TextBlock Text="{Binding BalancedHint}" TextWrapping="Wrap" Style="{StaticResource Sub}" Margin="24,1,0,8"/>

                    <RadioButton GroupName="San" IsChecked="{Binding IsOff}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" Content="关闭 — 识别最准（发送真实相对路径）"/>
                    <TextBlock Text="{Binding OffHint}" TextWrapping="Wrap" Style="{StaticResource Sub}" Margin="24,1,0,8"/>

                    <TextBlock Text="无论哪一档，CleanScope 都绝不发送文件内容，只发送路径/名称等元数据。"
                               Style="{StaticResource Sub}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="🗎 查看日志" Command="{Binding OpenLogCommand}" Style="{StaticResource Ghost}" Margin="0,0,10,0"
                        ToolTip="打开本地诊断日志：AI 失败的真实原因（鉴权/模型名/网络/截断等）都记在这里"/>
                <Button Content="测试连接" Command="{Binding TestCommand}" Style="{StaticResource Ghost}" Margin="0,0,10,0"/>
                <Button Command="{Binding SaveCommand}" Style="{StaticResource Primary}" MinWidth="132">
                    <Grid>
                        <!-- 闲置 -->
                        <TextBlock Text="保存" VerticalAlignment="Center"
                                   Visibility="{Binding ShowSaveIdle, Converter={StaticResource BoolToVis}}"/>
                        <!-- 保存中: 旋转环 + 文案 -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="14" Height="14" Stroke="White" StrokeThickness="2" StrokeDashArray="3 2"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="spin"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="spin" Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="保存中…" Foreground="White" Margin="8,0,0,0"/>
                        </StackPanel>
                        <!-- 已生效 -->
                        <TextBlock Text="✓ 已生效" Foreground="White" VerticalAlignment="Center"
                                   Visibility="{Binding JustSaved, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Button>
            </StackPanel>

            <Border Background="#F3F6FB" CornerRadius="6" Padding="10,8"
                    Visibility="{Binding Status, Converter={StaticResource NotEmptyToVis}}">
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="{StaticResource Ink}"/>
            </Border>
        </StackPanel>
    </Border>
  </ScrollViewer>
</UserControl>
