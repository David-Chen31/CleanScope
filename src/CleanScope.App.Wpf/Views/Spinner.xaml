<UserControl x:Class="CleanScope.App.Wpf.Views.Spinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <!-- 复用型加载转圈 (问题#2): AI 识别/生成等耗时操作旁放一个, 让用户知道"在转, 没卡住"。 -->
    <Grid Width="{Binding Diameter, ElementName=Root}" Height="{Binding Diameter, ElementName=Root}">
        <Ellipse Stroke="{Binding Stroke, ElementName=Root}" StrokeThickness="2" StrokeDashArray="3 2.4"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="rot"/>
            </Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Ellipse.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="rot" Storyboard.TargetProperty="Angle"
                                             From="0" To="360" Duration="0:0:0.85"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
    </Grid>
</UserControl>
