<UserControl x:Class="CleanScope.App.Wpf.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:HomeViewModel}"
             mc:Ignorable="d" d:DesignWidth="860">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>

        <!-- 磁盘容量 -->
        <Border Style="{StaticResource Cards}">
            <StackPanel>
                <TextBlock Text="磁盘容量" Style="{StaticResource H2}"/>
                <TextBlock Text="{Binding DriveInfo}" Style="{StaticResource Sub}" Margin="0,0,0,8"/>
                <ProgressBar Height="10" Minimum="0" Maximum="1" Value="{Binding DriveUsedRatio, Mode=OneWay}"
                             Foreground="{StaticResource Accent}" Background="#EDF0F3" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- 扫描入口 (盘符优先) -->
        <Border Style="{StaticResource Cards}">
            <StackPanel>
                <TextBlock Text="清理哪个磁盘？" Style="{StaticResource H2}"/>
                <TextBlock Text="CleanScope 仅读取文件元数据与系统信息，全程不删除、不修改任何文件。"
                           Style="{StaticResource Sub}" Margin="0,0,0,10"/>

                <!-- 盘符芯片: 一键把目标设为某个磁盘根 -->
                <ItemsControl ItemsSource="{Binding AvailableDrives}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="0,0,8,8" Padding="14,7"
                                    Style="{StaticResource Ghost}"
                                    Command="{Binding DataContext.ScanDriveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="8,6" FontSize="13"
                             ToolTip="可填磁盘根 (如 C:\) 或任意文件夹路径"/>
                    <Button Grid.Column="1" Content="扫描此磁盘" Command="{Binding ScanCommand}"
                            Style="{StaticResource Primary}" Margin="10,0,0,0" MinWidth="96"/>
                    <Button Grid.Column="2" Content="🖥 扫描整台电脑" Command="{Binding ScanAllDrivesCommand}"
                            Style="{StaticResource Ghost}" Margin="8,0,0,0" MinWidth="120"
                            ToolTip="一次扫描本机所有固定磁盘，合并成一份总览"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox Content="管理员模式（更全的扫描覆盖）" IsChecked="{Binding AdminMode}"
                              VerticalAlignment="Center" Foreground="{StaticResource Ink}"/>
                </StackPanel>

                <Border Margin="0,12,0,0" Padding="10" CornerRadius="6" Background="#F3F6FB">
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Sub}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- 官方清理手段 (P0): 不依赖扫描, 始终可用; 启动 Windows 自带工具 -->
        <Border Style="{StaticResource Cards}" Visibility="{Binding HasOfficialActions, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="一键官方清理手段" Style="{StaticResource H2}"/>
                <TextBlock Text="这些是 Windows 自带的安全清理方式（关闭休眠、清空回收站、磁盘清理等）。CleanScope 不替你删文件，只启动官方工具，过程可见。"
                           Style="{StaticResource Sub}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding OfficialActions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F7F9FC" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                            <Border Background="#FDECEA" CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                    Visibility="{Binding NeedsAdmin, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="管理员" FontSize="11" Foreground="#C5221F"/>
                                            </Border>
                                            <!-- 执行方式: 打开 Windows 界面 / 应用内执行 (打消黑框疑虑) -->
                                            <Border CornerRadius="3" Padding="5,1" Margin="6,0,0,0" Background="#E8F0FE">
                                                <TextBlock Text="{Binding SurfaceTag}" FontSize="11" Foreground="#1F4E8C"/>
                                            </Border>
                                            <!-- 问题#3: 可恢复/不可恢复一眼可见 -->
                                            <Border CornerRadius="3" Padding="5,1" Margin="6,0,0,0" Background="#EEF1F5">
                                                <TextBlock FontSize="11">
                                                    <Run Text="{Binding ReversibleBadge, Mode=OneWay}"/>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#1E7E34"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsIrreversible}" Value="True">
                                                                    <Setter Property="Foreground" Value="#C5221F"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding Action.Consequence}" Style="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,2,0,0"
                                                   Foreground="{StaticResource Muted}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding SavingsText}" VerticalAlignment="Center" Margin="0,0,12,0"
                                               FontWeight="Bold" Foreground="#1E7E34"
                                               Visibility="{Binding HasSavings, Converter={StaticResource BoolToVis}}"/>
                                    <Button Grid.Column="2" Content="{Binding RunButtonText}" VerticalAlignment="Center" MinWidth="110"
                                            Style="{StaticResource Ghost}"
                                            Command="{Binding DataContext.RunOfficialActionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- #1: 执行中显示不确定进度条, 让"清空回收站"等命令也有明确的"正在进行"反馈 -->
                <ProgressBar Height="6" IsIndeterminate="True" Margin="2,8,2,0" BorderThickness="0"
                             Foreground="{StaticResource Accent}" Background="#EDF0F3"
                             Visibility="{Binding IsOfficialRunning, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding OfficialStatus}" Style="{StaticResource Sub}" Margin="2,4,0,0"
                           Visibility="{Binding OfficialStatus, Converter={StaticResource NotEmptyToVis}}"/>
            </StackPanel>
        </Border>

        <!-- 扫描后概览 -->
        <Border Style="{StaticResource Cards}" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="本次扫描概览" Style="{StaticResource H2}"/>

                <UniformGrid Columns="3" Margin="0,4,0,12">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="根聚合占用" Style="{StaticResource Sub}"/>
                        <TextBlock Text="{Binding OverviewTotal}" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource Ink}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="可清理估算（A+B，仍需确认）" Style="{StaticResource Sub}"/>
                        <TextBlock Text="{Binding OverviewReclaimable}" FontSize="18" FontWeight="Bold"
                                   Foreground="#1E7E34"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="高风险项（D/E，不建议删除）" Style="{StaticResource Sub}"/>
                        <TextBlock Text="{Binding HighRiskCount}" FontSize="18" FontWeight="Bold"
                                   Foreground="#C5221F"/>
                    </StackPanel>
                </UniformGrid>

                <!-- S-H: 整盘 AI 清理参谋 —— 按需生成 (零默认 token); 未配置 AI 时按钮不显示 -->
                <StackPanel Margin="0,0,0,12" Visibility="{Binding ShowAdviseButton, Converter={StaticResource BoolToVis}}">
                    <Button Content="🧭 生成 AI 行动计划（结合本机官方手段，脱敏后请求一次，可选）" Command="{Binding AdviseCommand}"
                            Style="{StaticResource Ghost}" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding AdviseStatus}" Style="{StaticResource Sub}" Margin="2,6,0,0"
                               Visibility="{Binding AdviseStatus, Converter={StaticResource NotEmptyToVis}}"/>
                </StackPanel>

                <!-- 生成成功后展示参谋建议 -->
                <Border Background="#F1F7FF" CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                        Visibility="{Binding HasAiAdvice, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="🧭 AI 清理行动计划（跨项建议，仅供参考）" FontWeight="SemiBold" Foreground="#1F4E8C"/>
                        <TextBlock Text="{Binding AiAdvice}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#243B53"/>
                    </StackPanel>
                </Border>

                <!-- 最划算的几步: 最大的"可清理"项 (取代旧 Top10 最大目录, 后者多为不可动容器) -->
                <TextBlock Text="最划算的几步（最大的可清理项）" Style="{StaticResource H2}"
                           Visibility="{Binding HasBestCleanable, Converter={StaticResource BoolToVis}}"/>
                <ItemsControl ItemsSource="{Binding BestCleanable}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding SizeText}" FontWeight="Bold"
                                           Foreground="#1E7E34" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource Ink}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Path}" TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="去可清理清单批量处理 →" Command="{Binding ViewListCommand}"
                        Style="{StaticResource Ghost}" HorizontalAlignment="Left" Margin="0,14,0,0"/>
            </StackPanel>
        </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
