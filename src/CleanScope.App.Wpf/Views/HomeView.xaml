<UserControl x:Class="CleanScope.App.Wpf.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:views="clr-namespace:CleanScope.App.Wpf.Views"
             xmlns:common="clr-namespace:CleanScope.App.Wpf.Common"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:HomeViewModel}"
             mc:Ignorable="d" d:DesignWidth="860">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>

        <!-- ===== Hero: 一个主操作 (品牌价值标题 + 磁盘焦点 + 主按钮) ===== -->
        <!-- Hero 背景用主题 token (随深浅主题适配; 见 Themes/*.xaml 的 HeroBottom) -->
        <Border Style="{StaticResource Cards}" Padding="28,26" Background="{DynamicResource HeroBottom}">
            <StackPanel>
                <!-- 工作台首屏: 去掉大标题/口号 (占注意力且无用), 仅保留一行安全承诺作信任锚 (扫描前) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <Path Data="{StaticResource IconShield}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Clean}"
                          Width="13" Height="13" Margin="0,0,6,0"/>
                    <TextBlock Text="只读分析 · 删除只进回收站可还原 · 系统关键文件零触碰"
                               FontSize="12.5" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="{Binding DriveInfo}" FontSize="13.5" Foreground="{DynamicResource Muted}"
                           Margin="0,12,0,12"/>
                <ProgressBar Height="10" Minimum="0" Maximum="1" Value="{Binding DriveUsedRatio, Mode=OneWay}"
                             Foreground="{Binding DriveUsedRatio, Converter={StaticResource UsageToBrush}}"
                             Background="{DynamicResource Track}" BorderThickness="0"/>

                <!-- 盘符芯片 -->
                <ItemsControl ItemsSource="{Binding AvailableDrives}" Margin="0,18,0,10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="0,0,8,0" Padding="16,7"
                                    Style="{StaticResource Ghost}"
                                    Command="{Binding DataContext.ScanDriveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 路径 + 主操作 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Field}" VerticalAlignment="Center"
                             ToolTip="可填磁盘根 (如 C:\) 或任意文件夹路径"/>
                    <Button Grid.Column="1" Content="扫描此磁盘  →" Command="{Binding ScanCommand}" IsDefault="True"
                            Style="{StaticResource Primary}" Margin="12,0,0,0" MinWidth="150"
                            FontSize="15" Padding="24,12"
                            ToolTip="快捷键：在路径框按 Enter 即可扫描"/>
                </Grid>

                <!-- 次要选项: 整台电脑 + 管理员模式 (弱化, 不抢主操作) -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                    <Button Command="{Binding ScanAllDrivesCommand}" Style="{StaticResource Ghost}" Padding="12,6"
                            ToolTip="一次扫描本机所有固定磁盘，合并成一份总览">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconMonitor}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Accent}"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="扫描整台电脑" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <CheckBox Content="管理员模式（更全覆盖）" IsChecked="{Binding AdminMode}"
                              VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{DynamicResource Muted}"/>
                </StackPanel>

                <!-- 扫描进行中反馈 -->
                <ProgressBar Height="4" IsIndeterminate="True" Margin="0,14,0,0" BorderThickness="0"
                             Foreground="{DynamicResource Accent}" Background="{DynamicResource Track}"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding Status}" Style="{StaticResource Sub}" Margin="2,10,0,0"/>

                <!-- P5: 累计清理战绩 (跨会话, 本机) -->
                <StackPanel Orientation="Horizontal" Margin="2,12,0,0" VerticalAlignment="Center"
                            Visibility="{Binding HasLifetimeCleaned, Converter={StaticResource BoolToVis}}">
                    <Path Data="{StaticResource IconCheck}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Clean}"
                          Width="13" Height="13" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding LifetimeCleanedText}" FontSize="12.5" Foreground="{DynamicResource Clean}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- H: 最近扫描 (扫描前展示, 一键回到上次目标) -->
        <Border Style="{StaticResource Cards}" Visibility="{Binding ShowRecentScans, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="最近扫描" Style="{StaticResource H2}"/>
                <TextBlock Text="点任意一条即可一键重新扫描该位置。" Style="{StaticResource Sub}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding RecentScans}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.RescanRecentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding Target}" Style="{StaticResource RowButton}"
                                    Margin="0,0,0,6" Padding="12,10"
                                    BorderBrush="{DynamicResource Line}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 文件夹图标 -->
                                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8" Background="{DynamicResource AccentSoft}"
                                            VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Path Data="{StaticResource IconMonitor}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Accent}"
                                              Width="17" Height="17"/>
                                    </Border>
                                    <!-- 目标 + 元信息 (左对齐, 填满宽度) -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Target}" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"
                                                   FontSize="13.5" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Foreground="{DynamicResource Muted}" FontSize="11.5" Margin="0,2,0,0">
                                            <Run Text="{Binding SizeText, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding CountText, Mode=OneWay}"/><Run Text="　"/><Run Text="{Binding WhenText, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- 重扫 -->
                                    <Border Grid.Column="2" Style="{StaticResource Chip}" Background="{DynamicResource AccentSoft}" VerticalAlignment="Center">
                                        <TextBlock Text="重扫 →" Foreground="{DynamicResource Accent}" FontSize="12.5" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 扫描后概览 (评审问题#4: 工作台首屏先给结果, 排在官方清理之上) -->
        <Border Style="{StaticResource Cards}" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="本次扫描概览" Style="{StaticResource H2}"/>

                <UniformGrid Columns="3" Margin="0,4,0,12">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="根聚合占用" Style="{StaticResource Sub}"/>
                        <TextBlock Text="{Binding OverviewTotal}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource Ink}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="可清理估算（A+B，仍需确认）" Style="{StaticResource Sub}"/>
                        <TextBlock Text="{Binding OverviewReclaimable}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource Clean}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="高风险项（D/E，不建议删除）" Style="{StaticResource Sub}"/>
                        <TextBlock Text="{Binding HighRiskCount}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource Critical}"/>
                    </StackPanel>
                </UniformGrid>

                <!-- ========== 清理中心: 由浅入深的三步 (一键放心清理 → 按软件深清 → 深度腾空间) ========== -->

                <!-- 第一步 · 一键放心清理 (浅层, 90% 够用; 唯一主操作) -->
                <Border Background="{DynamicResource CleanSoft}" CornerRadius="10" Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13" Background="{DynamicResource Clean}"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="一键放心清理" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource Ink}"/>
                                <TextBlock Text="缓存、临时、可重建文件等已判安全的项，移入回收站可还原。" Style="{StaticResource Sub}" Margin="0,1,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource Chip}" Background="{DynamicResource Card}" Margin="8,0,10,0"
                                    VerticalAlignment="Center" Visibility="{Binding ShowOneClickClean, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource Clean}">
                                    <Run Text="约 "/><Run Text="{Binding OverviewReclaimable, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                            <Button Grid.Column="3" Command="{Binding OneClickCleanCommand}" Style="{StaticResource Primary}"
                                    Padding="20,10" MinWidth="120" VerticalAlignment="Center"
                                    Visibility="{Binding ShowOneClickClean, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconTrash}" Style="{StaticResource IconStroke}" Stroke="White"
                                          Width="15" Height="15" Margin="0,0,7,0"/>
                                    <TextBlock Text="一键清理" VerticalAlignment="Center" FontSize="14.5"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="本次没有发现可放心清理的项 —— 看看下面第二、三步。" Style="{StaticResource Sub}" Margin="36,6,0,0"
                                   Visibility="{Binding ShowOneClickClean, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        <ProgressBar Height="4" IsIndeterminate="True" Margin="2,8,2,0" BorderThickness="0"
                                     Foreground="{DynamicResource Clean}" Background="{DynamicResource Track}"
                                     Visibility="{Binding IsCleaning, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <!-- P4: 清理后前后对比 (诚实: 回收不立即释放磁盘 → 给"清空回收站后"的投影对比) -->
                <Border Background="{DynamicResource Subtle}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                        CornerRadius="8" Padding="14,12" Margin="0,0,0,12"
                        Visibility="{Binding CleanResultVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding CleanResultText}" TextWrapping="Wrap" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Ink}"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="现在" Style="{StaticResource Sub}" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Row="0" Grid.Column="1" Height="10" Minimum="0" Maximum="1" Margin="0,0,8,0"
                                         Value="{Binding CleanBeforeRatio, Mode=OneWay}" BorderThickness="0"
                                         Foreground="{DynamicResource Muted}" Background="{DynamicResource Track}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CleanBeforePercent}" Style="{StaticResource Sub}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="清空回收站后(约)" Style="{StaticResource Sub}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <ProgressBar Grid.Row="1" Grid.Column="1" Height="10" Minimum="0" Maximum="1" Margin="0,6,8,0"
                                         Value="{Binding CleanAfterRatio, Mode=OneWay}" BorderThickness="0"
                                         Foreground="{DynamicResource Clean}" Background="{DynamicResource Track}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CleanAfterPercent}" Style="{StaticResource Sub}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                        </Grid>
                        <TextBlock Text="{Binding CleanResultNote}" Style="{StaticResource Sub}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <Button HorizontalAlignment="Left" Margin="0,10,0,0" Style="{StaticResource Ghost}" Padding="14,7"
                                Command="{Binding RunOfficialActionCommand}" CommandParameter="{Binding EmptyRecycleBinAction}"
                                Visibility="{Binding HasEmptyRecycleBin, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconTrash}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Critical}"
                                      Width="14" Height="14" Margin="0,0,6,0"/>
                                <TextBlock Text="清空回收站，彻底释放（确认无误后）" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- 第二步 · 按软件深清 (针对性: 微信/QQ/浏览器/IDE… 各自占多少、可清多少) -->
                <Border Background="{DynamicResource Subtle}" CornerRadius="10" Padding="16,14" Margin="0,0,0,12"
                        Visibility="{Binding HasTopSoftware, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13" Background="{DynamicResource Accent}"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="2" Foreground="White" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="按软件深清" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource Ink}"/>
                                <TextBlock Text="想再清点？看看谁占了地，点进去按软件清那一个。" Style="{StaticResource Sub}" Margin="0,1,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="全部 →" Command="{Binding GoBySoftwareCommand}"
                                    Style="{StaticResource Ghost}" Padding="12,6" VerticalAlignment="Center"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding TopSoftware}" Margin="36,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.GoBySoftwareCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            Style="{StaticResource RowButton}" Padding="10,7" Margin="0,0,0,5"
                                            BorderBrush="{DynamicResource Line}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{DynamicResource Ink}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalText}" Foreground="{DynamicResource Muted}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <Border Grid.Column="2" Style="{StaticResource Chip}" Background="{DynamicResource CleanSoft}"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasCleanable, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding CleanableText}" FontSize="11.5" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Clean}"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 第三步 · 深度腾空间 (进阶, 需你判断: 迁移大目录 / 浏览目录树 / 官方手段在下方) -->
                <Border Background="{DynamicResource Subtle}" CornerRadius="10" Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13" Background="{DynamicResource Faint}"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="3" Foreground="White" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="深度腾空间（进阶）" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource Ink}"/>
                                <TextBlock Text="占地大但不能删的，可迁移到其他盘（软件照常用）；或浏览整盘目录树自己定夺。" Style="{StaticResource Sub}" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="36,8,0,0">
                            <Button Command="{Binding GoExplorerCommand}" Style="{StaticResource Ghost}" Padding="12,7" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconRestore}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Accent}"
                                          Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="浏览目录树 · 迁移大目录" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="还想更彻底？下方「Windows 官方清理」可关休眠、清组件(DISM)、删 Windows.old、优化驱动器等。"
                                   Style="{StaticResource Sub}" Margin="36,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- AI 解读: 降为可选小入口 (不再是并列大按钮); 未配置 AI 不显示 -->
                <StackPanel Margin="0,0,0,12" Visibility="{Binding ShowAdviseButton, Converter={StaticResource BoolToVis}}">
                    <Button Command="{Binding AdviseCommand}" Style="{StaticResource RowButton}" HorizontalAlignment="Left" Padding="10,7"
                            ToolTip="基于占用汇总(不含路径)请求一次，让 AI 跨项解读并给建议（可选）">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconAi}" Style="{StaticResource IconFill}" Fill="{DynamicResource Ai}"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="让 AI 解读这次结果并给建议" Foreground="{DynamicResource Ai}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal" Margin="2,8,0,0" VerticalAlignment="Center"
                                Visibility="{Binding AdviseStatus, Converter={StaticResource NotEmptyToVis}}">
                        <views:Spinner Diameter="14" VerticalAlignment="Center"
                                       Visibility="{Binding IsAdvising, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding AdviseStatus}" Style="{StaticResource Sub}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- 生成成功后展示参谋建议 -->
                <Border Background="{DynamicResource AccentSoft}" CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                        Visibility="{Binding HasAiAdvice, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlan}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Accent}"
                                  Width="15" Height="15" Margin="0,0,7,0"/>
                            <TextBlock Text="AI 清理行动计划（跨项建议，仅供参考）" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 一句话总览 (有结构化计划时) -->
                        <TextBlock Text="{Binding PlanSummary}" TextWrapping="Wrap" Margin="0,6,0,0" FontSize="13.5"
                                   Foreground="{DynamicResource Ink}" FontWeight="SemiBold"
                                   Visibility="{Binding HasPlanSummary, Converter={StaticResource BoolToVis}}"/>

                        <!-- 问题#1: 结构化分步卡片 —— 小白扫读「标题/省多少/难度/在哪做」, 想了解原因再点「为什么」展开 -->
                        <ItemsControl ItemsSource="{Binding PlanSteps}" Margin="0,8,0,0"
                                      Visibility="{Binding HasPlanSteps, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Card}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 步骤序号 -->
                                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                                        Background="{DynamicResource Accent}" VerticalAlignment="Top" Margin="0,1,10,0">
                                                    <TextBlock Text="{Binding Order}" Foreground="White" FontWeight="Bold" FontSize="13"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- 标题 (一句话动作) -->
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap"
                                                           FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Ink}"
                                                           VerticalAlignment="Center"/>
                                                <!-- 省多少 (绿色, 一眼看价值) -->
                                                <Border Grid.Column="2" Style="{StaticResource Chip}" Background="{DynamicResource CleanSoft}"
                                                        VerticalAlignment="Top" Margin="8,1,0,0"
                                                        Visibility="{Binding HasSaving, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding Saving}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Clean}"/>
                                                </Border>
                                            </Grid>

                                            <!-- 难度 + 在哪做 chips + 「为什么」展开 -->
                                            <StackPanel Orientation="Horizontal" Margin="34,7,0,0">
                                                <Border Style="{StaticResource Chip}" Background="{DynamicResource Subtle}" Margin="0,0,6,0"
                                                        Visibility="{Binding HasDifficulty, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="7" Height="7" Fill="{Binding DifficultyColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding Difficulty}" FontSize="12" Foreground="{Binding DifficultyColor}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource Chip}" Background="{DynamicResource AccentSoft}" Margin="0,0,6,0"
                                                        Visibility="{Binding HasWhere, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock FontSize="12" Foreground="{DynamicResource Accent}">
                                                        <Run Text="在哪做："/><Run Text="{Binding Where, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                                <Button Content="{Binding ToggleLabel}" Command="{Binding ToggleDetailCommand}"
                                                        Style="{StaticResource Ghost}" Padding="8,3" FontSize="12"
                                                        Visibility="{Binding HasDetail, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>

                                            <!-- 展开: 为什么这么做 / 删了影响什么 -->
                                            <Border Background="{DynamicResource Subtle}" CornerRadius="6" Padding="10,8" Margin="34,8,0,0"
                                                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" FontSize="12.5"
                                                           Foreground="{DynamicResource Muted}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 末尾提醒 -->
                        <TextBlock Text="{Binding PlanNote}" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="12.5"
                                   Foreground="{DynamicResource Muted}"
                                   Visibility="{Binding HasPlanNote, Converter={StaticResource BoolToVis}}"/>

                        <!-- 回退: 无结构化步骤 (旧会话 / 解析失败) 时, 仍以纯文本展示原建议 -->
                        <TextBlock common:MarkdownInline.Text="{Binding AiAdvice}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="{DynamicResource Ink}"
                                   Visibility="{Binding ShowAdviceText, Converter={StaticResource BoolToVis}}"/>

                        <!-- 问题#1: 计划不再止于文字 —— 紧跟可一键执行的官方手段按钮, 点了即先确认再执行, 不用开命令行 -->
                        <Border Background="{DynamicResource Card}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6"
                                Padding="10,8" Margin="0,10,0,0"
                                Visibility="{Binding HasApplicableOfficialActions, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="↓ 按计划一键执行（点击后会先弹出确认，无需命令行）" FontSize="12"
                                           Foreground="{DynamicResource Muted}" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding ApplicableOfficialActions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,8,8" Style="{StaticResource Ghost}" Padding="12,7"
                                                    Command="{Binding DataContext.RunOfficialActionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding SavingsText}" Margin="6,0,0,0" FontSize="11"
                                                               Foreground="{DynamicResource Clean}" VerticalAlignment="Center"
                                                               Visibility="{Binding HasSavings, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- 官方清理手段 (P0): 不依赖扫描, 始终可用; 启动 Windows 自带工具 -->
        <Border Style="{StaticResource Cards}" Visibility="{Binding HasOfficialActions, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Windows 官方清理" Style="{StaticResource H2}"/>
                <TextBlock Text="调用系统自带工具，过程你可控。" Style="{StaticResource Sub}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding OfficialActions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Subtle}" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
                                            <Border Background="{DynamicResource CriticalSoft}" CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                    Visibility="{Binding NeedsAdmin, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="管理员" FontSize="11" Foreground="{DynamicResource Critical}"/>
                                            </Border>
                                            <!-- 执行方式: 打开 Windows 界面 / 应用内执行 (打消黑框疑虑) -->
                                            <Border CornerRadius="3" Padding="5,1" Margin="6,0,0,0" Background="{DynamicResource AccentSoft}">
                                                <TextBlock Text="{Binding SurfaceTag}" FontSize="11" Foreground="{DynamicResource Accent}"/>
                                            </Border>
                                            <!-- 问题#3: 可恢复/不可恢复一眼可见 -->
                                            <Border CornerRadius="3" Padding="5,1" Margin="6,0,0,0" Background="{DynamicResource Subtle}">
                                                <TextBlock FontSize="11">
                                                    <Run Text="{Binding ReversibleBadge, Mode=OneWay}"/>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource Clean}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsIrreversible}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Critical}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource Sub}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding SavingsText}" VerticalAlignment="Center" Margin="0,0,12,0"
                                               FontWeight="Bold" Foreground="{DynamicResource Clean}"
                                               Visibility="{Binding HasSavings, Converter={StaticResource BoolToVis}}"/>
                                    <Button Grid.Column="2" Content="{Binding RunButtonText}" VerticalAlignment="Center" MinWidth="110"
                                            Style="{StaticResource Ghost}"
                                            Command="{Binding DataContext.RunOfficialActionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- #1: 执行中显示不确定进度条, 让"清空回收站"等命令也有明确的"正在进行"反馈 -->
                <ProgressBar Height="6" IsIndeterminate="True" Margin="2,8,2,0" BorderThickness="0"
                             Foreground="{DynamicResource Accent}" Background="{DynamicResource Track}"
                             Visibility="{Binding IsOfficialRunning, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding OfficialStatus}" Style="{StaticResource Sub}" Margin="2,4,0,0"
                           Visibility="{Binding OfficialStatus, Converter={StaticResource NotEmptyToVis}}"/>
            </StackPanel>
        </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
