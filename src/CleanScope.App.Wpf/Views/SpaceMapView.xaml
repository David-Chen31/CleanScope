<UserControl x:Class="CleanScope.App.Wpf.Views.SpaceMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:SpaceMapViewModel}"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="600">
    <Border Style="{StaticResource Cards}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="空间地图（矩形树图）" Style="{StaticResource H2}"/>

            <!-- 问题#2: 真实磁盘占用为准, 说明逻辑合计为何可能更大 (硬链接/稀疏文件) -->
            <Border DockPanel.Dock="Top" Background="#F3F6FB" CornerRadius="6" Padding="10,7" Margin="0,0,0,8"
                    Visibility="{Binding HasDiskHint, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding DiskHint}" TextWrapping="Wrap" Foreground="{StaticResource Ink}"/>
            </Border>

            <!-- 面包屑 + 返回上层 -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button DockPanel.Dock="Left" Content="↑ 上一层" Command="{Binding UpCommand}"
                        Style="{StaticResource Ghost}" Margin="0,0,10,0"/>
                <ItemsControl ItemsSource="{Binding Breadcrumb}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding Name}"
                                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource Accent}"
                                        Cursor="Hand" Padding="2,0"/>
                                <TextBlock Text=" ›" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <TextBlock DockPanel.Dock="Top" Text="{Binding Hint}" Style="{StaticResource Sub}" Margin="0,0,0,8"/>

            <!-- P2 风险图例 = 页面主角: 颜色不是装饰, 而是"风险等级"; 一眼读懂红=勿动、蓝灰=你的资料、✓=可清理 -->
            <Border DockPanel.Dock="Top" Background="{StaticResource Subtle}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="颜色 = 风险等级（不只是占用大小）" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                            <Border Background="#9BD3AE" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                            <TextBlock Text="A 可放心清理" Style="{StaticResource Sub}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                            <Border Background="#A9C7F5" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                            <TextBlock Text="B 基本安全" Style="{StaticResource Sub}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                            <Border Background="#F4D58A" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                            <TextBlock Text="C 谨慎 · 删前确认" Style="{StaticResource Sub}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                            <Border Background="#F0A8A4" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                            <TextBlock Text="D 高风险 · 不建议删" Style="{StaticResource Sub}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                            <Border Background="#C98B88" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                            <TextBlock Text="E 系统关键 · 勿动" Style="{StaticResource Sub}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Data="{StaticResource IconCheck}" Style="{StaticResource IconStroke}" Stroke="#1E7E34"
                                  Width="13" Height="13" Margin="0,0,5,0"/>
                            <TextBlock Text="角标 = 可清理（可勾选批量回收）" Style="{StaticResource Sub}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="4" MinHeight="420">
                <Canvas x:Name="MapCanvas" ClipToBounds="True" Background="#FAFBFC"
                        SizeChanged="MapCanvas_SizeChanged"/>
            </Border>
        </DockPanel>
    </Border>
</UserControl>
