<UserControl x:Class="CleanScope.App.Wpf.Views.ExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:views="clr-namespace:CleanScope.App.Wpf.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:ExplorerViewModel}"
             mc:Ignorable="d" d:DesignWidth="900">
    <Border Style="{StaticResource Cards}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== 头部: 标题 + 只看可清理 + 概览 + 批量条 ===== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <Grid>
                    <TextBlock Text="资源管理器（整盘目录树 · 可清理清单）" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                    <CheckBox Content="只看可清理（扁平，可勾选批量清理）" IsChecked="{Binding ShowCleanableOnly}"
                              HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource Clean}" FontWeight="SemiBold"/>
                </Grid>

                <!-- F1/问题2: 搜索 / 路径定位 —— 按名称或路径过滤当前扫描结果 -->
                <Border Background="{DynamicResource Subtle}" CornerRadius="8" BorderBrush="{DynamicResource Line}"
                        BorderThickness="1" Margin="0,10,0,8" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Faint}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                        <Grid Grid.Column="1">
                            <!-- 水印在底层 (TextBox 透明背景透出); 有文字时 TextBox 文字盖在其上, 且水印随 IsSearching 隐藏 -->
                            <TextBlock Text="按名称或路径搜索当前结果…（可粘贴路径片段定位）" Foreground="{DynamicResource Faint}"
                                       VerticalAlignment="Center" Margin="2,0,0,0" IsHitTestVisible="False"
                                       Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                            <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                     Padding="0,8" Foreground="{DynamicResource Ink}"
                                     AutomationProperties.Name="搜索当前扫描结果"/>
                        </Grid>
                        <Button Grid.Column="2" Content="✕ 清除" Command="{Binding ClearSearchCommand}"
                                Style="{StaticResource Ghost}" Padding="8,4" Margin="6,0,0,0"
                                Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>

                <TextBlock Text="{Binding Summary}" Style="{StaticResource Sub}"/>

                <!-- C1 批量操作条 ("只看可清理"恒显示; 普通树模式勾选任意项也出现) -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                            Visibility="{Binding ShowBatchBar, Converter={StaticResource BoolToVis}}">
                    <Button Content="全选" Command="{Binding SelectAllCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,0"
                            Visibility="{Binding ShowCleanableOnly, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="全不选" Command="{Binding SelectNoneCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,0"/>
                    <Button Command="{Binding RecycleSelectedCommand}" Style="{StaticResource Primary}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconTrash}" Style="{StaticResource IconStroke}" Stroke="White"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="移入回收站（可还原）" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- 问题#1: 对勾选项批量 AI 识别 (仅配置了 AI 时出现) -->
                    <Button Command="{Binding InvestigateSelectedCommand}" Style="{StaticResource Ghost}" Margin="0,0,12,0"
                            ToolTip="对勾选的项逐个用 AI 识别来源/用途（脱敏后请求；命中缓存/已识别的会跳过）"
                            Visibility="{Binding ShowBatchAi, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconAi}" Style="{StaticResource IconFill}" Fill="{DynamicResource Ai}"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="用 AI 识别选中" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="排序" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" Margin="0,0,4,0"
                               Visibility="{Binding ShowCleanableOnly, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="大小" Command="{Binding SortBySizeCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,0"
                            Visibility="{Binding ShowCleanableOnly, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="名称" Command="{Binding SortByNameCommand}" Style="{StaticResource Ghost}" Margin="0,0,16,0"
                            Visibility="{Binding ShowCleanableOnly, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding SelectionSummary}" VerticalAlignment="Center" Style="{StaticResource Sub}"/>
                </StackPanel>
            </StackPanel>

            <!-- ===== 主从同屏: 左=目录树(master) | 右=常驻解释面板(detail) ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="320"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="360" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- ───── master: 目录树 ───── -->
                <TreeView x:Name="Tree" Grid.Column="0" ItemsSource="{Binding Roots}" BorderThickness="0" Background="Transparent"
                          SelectedItemChanged="Tree_SelectedItemChanged"
                          PreviewMouseRightButtonDown="Tree_PreviewMouseRightButtonDown"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <TreeView.Resources>
                        <!-- E4: 选中行浅蓝高亮 + 深色文字 -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D6E6FB"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1A1A1A"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E7EEF8"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1A1A1A"/>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Padding" Value="0,2"/>
                            <!-- 系统默认 TreeViewItem 样式会把 Foreground 钉成黑色, 截断继承; 显式置 Ink 让暗色节点文字可读。 -->
                            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid Margin="0,1">
                                <Grid.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}"/>
                                        <MenuItem Header="复制用途 / 说明" Command="{Binding CopyPurposeCommand}"
                                                  Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                        <MenuItem Header="在资源管理器中打开位置" Command="{Binding OpenLocationCommand}"
                                                  Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                        <MenuItem Header="加入忽略名单" Command="{Binding AddIgnoreCommand}"
                                                  Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                        <MenuItem Header="用 AI 识别用途 / 归属（推测）" Command="{Binding InvestigateCommand}"
                                                  Visibility="{Binding ShowAiMenu, Converter={StaticResource BoolToVis}}"/>
                                        <Separator Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                        <MenuItem Header="迁移到其他盘（建目录联接，省 C 盘且软件照常用）" Command="{Binding MigrateCommand}"
                                                  Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                        <MenuItem Header="移入回收站（可还原）" Command="{Binding RecycleCommand}"
                                                  Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                        <MenuItem Header="在回收站中查看 / 还原" Command="{Binding OpenRecycleBinCommand}"
                                                  Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVis}}"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 名称 + 勾选 + A–E 等级徽章(品牌签名, 取代红黄绿点) + 图标 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0"
                                              Visibility="{Binding CanSelect, Converter={StaticResource BoolToVis}}"/>
                                    <!-- 等级徽章: 有字母→彩色方块字母(A–E); 无字母→中性圆点(个人/容器/余量) -->
                                    <Grid Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border Background="{Binding Grade.Chip}" CornerRadius="4"
                                                Visibility="{Binding Grade.HasLetter, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding Grade.Letter}" Foreground="White" FontWeight="Bold" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="{Binding Grade.Chip}" CornerRadius="5" Width="10" Height="10"
                                                Visibility="{Binding Grade.HasLetter, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Glyph}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                                                Visibility="{Binding IsCleanable, Converter={StaticResource BoolToVis}}">
                                        <Path Data="{StaticResource IconCheck}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Clean}"
                                              Width="11" Height="11" Margin="0,0,3,0"/>
                                        <TextBlock Text="可清理" Foreground="{DynamicResource Clean}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                                                Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVis}}">
                                        <Path Data="{StaticResource IconRestore}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Muted}"
                                              Width="11" Height="11" Margin="0,0,3,0"/>
                                        <TextBlock Text="已移入回收站" Foreground="{DynamicResource Muted}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                                                ToolTip="来源/用途由 AI 推测补充，仅供参考"
                                                Visibility="{Binding IsAiResolved, Converter={StaticResource BoolToVis}}">
                                        <Path Data="{StaticResource IconAi}" Style="{StaticResource IconFill}" Fill="{DynamicResource Ai}"
                                              Width="11" Height="11" Margin="0,0,3,0"/>
                                        <TextBlock Text="AI推测" Foreground="{DynamicResource Ai}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0"
                                                Visibility="{Binding IsInvestigating, Converter={StaticResource BoolToVis}}">
                                        <views:Spinner Diameter="11" Stroke="{DynamicResource Ai}" VerticalAlignment="Center"/>
                                        <TextBlock Text="识别中…" Foreground="{DynamicResource Ai}" FontSize="11" FontStyle="Italic"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 大小 + 占父目录比例条 (按等级配色统一) -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                    <TextBlock Text="{Binding SizeText}" HorizontalAlignment="Right" FontFamily="Consolas"/>
                                    <Border Height="4" CornerRadius="2" Background="{DynamicResource Track}" Margin="0,2,0,0">
                                        <Border HorizontalAlignment="Left" CornerRadius="2" Background="{Binding Grade.Chip}"
                                                Width="{Binding FractionOfParent, Converter={StaticResource FractionToWidth}, ConverterParameter=108}"/>
                                    </Border>
                                </StackPanel>

                                <!-- 来源 = 安静的小 chip (用途/建议在右侧解释面板) -->
                                <Border Grid.Column="2" Style="{StaticResource Chip}" Background="{DynamicResource Subtle}"
                                        Margin="10,0,0,0" ToolTip="{Binding Purpose}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Origin}" FontSize="12" Foreground="{DynamicResource Muted}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                </Border>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="Transparent" ResizeBehavior="PreviousAndNext" FocusVisualStyle="{x:Null}"/>

                <!-- ───── detail: 常驻解释面板 (解释优先 —— 永不离场) ───── -->
                <Border Grid.Column="2" CornerRadius="8" Background="{DynamicResource Subtle}"
                        BorderBrush="{DynamicResource Line}" BorderThickness="1" Padding="14,12">
                    <Grid>
                        <!-- 空态: 引导用户点击 -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12"
                                    Visibility="{Binding HasSelectedNode, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="30" Foreground="{DynamicResource Faint}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="选择左侧任意项" FontWeight="SemiBold" Foreground="{DynamicResource Muted}"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="这里会解释它是什么、归谁、删了会怎样，再由你决定。"
                                       TextWrapping="Wrap" TextAlignment="Center" Style="{StaticResource Sub}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- 选中态: 完整解释 + 该项动作 -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasSelectedNode, Converter={StaticResource BoolToVis}}">
                            <StackPanel DataContext="{Binding SelectedNode}">
                                <TextBlock Text="解释" Style="{StaticResource Caption}" Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource Ink}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource Muted}" Margin="0,3,0,0"/>

                                <!-- 风险等级徽章 (品牌主角: 大号字母 + 人话标签) -->
                                <Border CornerRadius="8" Background="{DynamicResource Card}" BorderBrush="{DynamicResource Line}"
                                        BorderThickness="1" Padding="10,9" Margin="0,12,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Grid Width="30" Height="30" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Border Background="{Binding Grade.Chip}" CornerRadius="7"
                                                    Visibility="{Binding Grade.HasLetter, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding Grade.Letter}" Foreground="White" FontWeight="Bold" FontSize="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Background="{Binding Grade.Chip}" CornerRadius="8" Width="16" Height="16"
                                                    Visibility="{Binding Grade.HasLetter, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        </Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="风险等级" FontSize="11" Foreground="{DynamicResource Muted}"/>
                                            <TextBlock Text="{Binding Grade.Label}" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 路径 (可选中复制) -->
                                <TextBox Text="{Binding Path, Mode=OneWay}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                         Foreground="{DynamicResource Muted}" Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12"/>

                                <!-- 来源 / 用途 / 建议 -->
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="来源 / 归属" FontSize="11" Foreground="{DynamicResource Muted}"/>
                                    <TextBlock Text="{Binding Origin}" TextWrapping="Wrap" Foreground="{DynamicResource Ink}" Margin="0,2,0,0"/>
                                    <TextBlock Text="用途 / 说明" FontSize="11" Foreground="{DynamicResource Muted}" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding Purpose}" TextWrapping="Wrap" Foreground="{DynamicResource Ink}" Margin="0,2,0,0"/>
                                    <TextBlock Text="建议" FontSize="11" Foreground="{DynamicResource Muted}" Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding RecommendedAction}" TextWrapping="Wrap" Foreground="{DynamicResource Ink}" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource Line}" Margin="0,14,0,12"/>

                                <!-- 行内动作: 选中项即可直接操作 -->
                                <WrapPanel>
                                    <Button Content="复制路径" Command="{Binding CopyPathCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"/>
                                    <Button Content="打开位置" Command="{Binding OpenLocationCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                            Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <Button Command="{Binding InvestigateCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                            Visibility="{Binding ShowAiMenu, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconAi}" Style="{StaticResource IconFill}" Fill="{DynamicResource Accent}"
                                                  Width="13" Height="13" Margin="0,0,6,0"/>
                                            <TextBlock Text="用 AI 识别" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Content="加入忽略名单" Command="{Binding AddIgnoreCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                            Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="迁移到其他盘" Command="{Binding MigrateCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                            Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <Button Command="{Binding RecycleCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                            Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconTrash}" Style="{StaticResource IconStroke}" Stroke="{DynamicResource Accent}"
                                                  Width="13" Height="13" Margin="0,0,6,0"/>
                                            <TextBlock Text="移入回收站" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Content="在回收站中查看 / 还原" Command="{Binding OpenRecycleBinCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                            Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVis}}"/>
                                </WrapPanel>

                                <!-- 问题#2: AI 识别进行中 —— 转圈 + 文案, 避免用户以为卡住 -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding IsInvestigating, Converter={StaticResource BoolToVis}}">
                                    <views:Spinner Diameter="14" Stroke="{DynamicResource Ai}" VerticalAlignment="Center"/>
                                    <TextBlock Text="正在用 AI 识别这一项…（脱敏后请求，仅供参考）" Foreground="{DynamicResource Ai}" FontSize="12"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 操作结果反馈 (复制/打开/移入回收站) -->
            <Border Grid.Row="2" Margin="0,8,0,0" Padding="10,6" CornerRadius="4" Background="{DynamicResource Subtle}"
                    Visibility="{Binding ActionStatus, Converter={StaticResource NotEmptyToVis}}">
                <TextBlock Text="{Binding ActionStatus}" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
