<UserControl x:Class="CleanScope.App.Wpf.Views.ExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:ExplorerViewModel}"
             mc:Ignorable="d" d:DesignWidth="900">
    <Border Style="{StaticResource Cards}">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid>
                    <TextBlock Text="资源管理器（整盘目录树）" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                    <CheckBox Content="✓ 只看可清理（扁平，含深埋缓存）" IsChecked="{Binding ShowCleanableOnly}"
                              HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#1E7E34" FontWeight="SemiBold"/>
                </Grid>
                <TextBlock Text="{Binding Summary}" Style="{StaticResource Sub}"/>
            </StackPanel>

            <!-- 操作结果反馈 (复制/打开/移入回收站) -->
            <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="10,6" CornerRadius="4" Background="#F2F5FA"
                    Visibility="{Binding ActionStatus, Converter={StaticResource NotEmptyToVis}}">
                <TextBlock Text="{Binding ActionStatus}" TextWrapping="Wrap"/>
            </Border>

            <!-- 列标题: 让用户分清各列含义 (来源/归属、用途) -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="名称（▸ 展开 / 文件为叶子）" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                <TextBlock Grid.Column="1" Text="大小 / 占比" FontWeight="Bold" HorizontalAlignment="Right" Margin="6,0" Foreground="{StaticResource Muted}"/>
                <TextBlock Grid.Column="2" Text="来源 / 归属" FontWeight="Bold" Margin="6,0" Foreground="{StaticResource Muted}"/>
                <TextBlock Grid.Column="3" Text="用途 / 存在解释" FontWeight="Bold" Margin="6,0" Foreground="{StaticResource Muted}"/>
            </Grid>

            <TreeView ItemsSource="{Binding Roots}" BorderThickness="0" Background="Transparent"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <TreeView.Resources>
                    <!-- E4: 选中行用浅蓝高亮 + 深色文字, 避免系统深蓝把灰色"用途"文字吞掉看不清。 -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D6E6FB"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E7EEF8"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1A1A1A"/>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="Padding" Value="0,2"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Grid Margin="0,1">
                            <Grid.ContextMenu>
                                <!-- ContextMenu 不在同一可视树, 需经 PlacementTarget 取回行的 DataContext -->
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}"/>
                                    <MenuItem Header="复制用途 / 说明" Command="{Binding CopyPurposeCommand}"/>
                                    <MenuItem Header="在资源管理器中打开位置" Command="{Binding OpenLocationCommand}"/>
                                    <!-- 仅在已配置 AI 时出现; 点一次发一次脱敏请求, 识别这个目录是什么 (推测) -->
                                    <MenuItem Header="用 AI 识别用途 / 归属（推测）" Command="{Binding InvestigateCommand}"
                                              Visibility="{Binding ShowAiMenu, Converter={StaticResource BoolToVis}}"/>
                                    <Separator/>
                                    <MenuItem Header="移入回收站（可还原）" Command="{Binding RecycleCommand}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 名称 + 四桶色点 + 文件/文件夹图标 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="10" Height="10" CornerRadius="2" Margin="0,0,8,0"
                                        Background="{Binding BucketBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Glyph}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <!-- 已移入回收站: 删除线 + 置灰 -->
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="  ✓可清理" Foreground="#1E7E34" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding IsCleanable, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="  ♻已移入回收站" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="  ✨AI推测" Foreground="#8451C4" FontSize="11" VerticalAlignment="Center"
                                           ToolTip="来源/用途由 AI 推测补充，仅供参考"
                                           Visibility="{Binding IsAiResolved, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <!-- 大小 + 占父目录比例条 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                <TextBlock Text="{Binding SizeText}" HorizontalAlignment="Right" FontFamily="Consolas"/>
                                <Border Height="4" CornerRadius="2" Background="#E6EAF0" Margin="0,2,0,0">
                                    <Border HorizontalAlignment="Left" CornerRadius="2" Background="{Binding BucketBrush}"
                                            Width="{Binding FractionOfParent, Converter={StaticResource FractionToWidth}, ConverterParameter=108}"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding Origin}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding Purpose}" Margin="6,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding Purpose}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding RecommendedAction}"
                                       Foreground="{StaticResource Muted}" Margin="6,0"/>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>
    </Border>
</UserControl>
