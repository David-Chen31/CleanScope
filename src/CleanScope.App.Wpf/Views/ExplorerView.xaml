<UserControl x:Class="CleanScope.App.Wpf.Views.ExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanScope.App.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:ExplorerViewModel}"
             mc:Ignorable="d" d:DesignWidth="900">
    <Border Style="{StaticResource Cards}">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid>
                    <TextBlock Text="资源管理器（整盘目录树 · 可清理清单）" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                    <CheckBox Content="✓ 只看可清理（扁平，可勾选批量清理）" IsChecked="{Binding ShowCleanableOnly}"
                              HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#1E7E34" FontWeight="SemiBold"/>
                </Grid>
                <TextBlock Text="{Binding Summary}" Style="{StaticResource Sub}"/>

                <!-- C1 批量操作条 (仅"只看可清理"显示): 全选/全不选/批量移入回收站 -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                            Visibility="{Binding ShowBatchBar, Converter={StaticResource BoolToVis}}">
                    <Button Content="全选" Command="{Binding SelectAllCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,0"/>
                    <Button Content="全不选" Command="{Binding SelectNoneCommand}" Style="{StaticResource Ghost}" Margin="0,0,8,0"/>
                    <Button Content="🗑 移入回收站（可还原）" Command="{Binding RecycleSelectedCommand}"
                            Style="{StaticResource Primary}" Margin="0,0,12,0"/>
                    <TextBlock Text="排序" VerticalAlignment="Center" Foreground="{StaticResource Muted}" Margin="0,0,4,0"/>
                    <Button Content="大小" Command="{Binding SortBySizeCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,0"/>
                    <Button Content="名称" Command="{Binding SortByNameCommand}" Style="{StaticResource Ghost}" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding SelectionSummary}" VerticalAlignment="Center" Style="{StaticResource Sub}"/>
                </StackPanel>
            </StackPanel>

            <!-- 操作结果反馈 (复制/打开/移入回收站) -->
            <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="10,6" CornerRadius="4" Background="#F2F5FA"
                    Visibility="{Binding ActionStatus, Converter={StaticResource NotEmptyToVis}}">
                <TextBlock Text="{Binding ActionStatus}" TextWrapping="Wrap"/>
            </Border>


            <!-- C2 详情面板: 选中某项后, 在底部完整展示来源/用途/AI 解释/建议 (长文本自动换行, 不必复制) + 该项动作 -->
            <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="12,10" CornerRadius="6"
                    Background="#F7F9FC" BorderBrush="{StaticResource Line}" BorderThickness="1"
                    Visibility="{Binding HasSelectedNode, Converter={StaticResource BoolToVis}}">
                <StackPanel DataContext="{Binding SelectedNode}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource Ink}" TextTrimming="CharacterEllipsis"/>
                        <Border Background="{Binding BucketBrush}" CornerRadius="3" Padding="6,1" Margin="8,0,0,0">
                            <TextBlock Text="{Binding BucketLabel}" FontSize="11" Foreground="#222"/>
                        </Border>
                        <TextBlock Text="{Binding SizeText}" Margin="10,0,0,0" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding Path, Mode=OneWay}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="来源 / 归属" FontSize="11" Foreground="{StaticResource Muted}"/>
                            <TextBlock Text="用途 / 说明" FontSize="11" Foreground="{StaticResource Muted}" Margin="0,6,0,0"/>
                            <TextBlock Text="建议" FontSize="11" Foreground="{StaticResource Muted}" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Origin}" TextWrapping="Wrap" Foreground="{StaticResource Ink}"/>
                            <TextBlock Text="{Binding Purpose}" TextWrapping="Wrap" Foreground="{StaticResource Ink}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding RecommendedAction}" TextWrapping="Wrap" Foreground="{StaticResource Ink}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                    <!-- 行内动作 (C3 可发现性): 选中项即可直接操作, 不必右键 -->
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="复制路径" Command="{Binding CopyPathCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"/>
                        <Button Content="打开位置" Command="{Binding OpenLocationCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="✨ 用 AI 识别" Command="{Binding InvestigateCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                Visibility="{Binding ShowAiMenu, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="加入忽略名单" Command="{Binding AddIgnoreCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="迁移到其他盘" Command="{Binding MigrateCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="🗑 移入回收站" Command="{Binding RecycleCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="⚠ 手动移入回收站（高风险，需强确认）" Command="{Binding ManualRecycleCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                Visibility="{Binding CanManualRecycle, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="在回收站中查看 / 还原" Command="{Binding OpenRecycleBinCommand}" Style="{StaticResource Ghost}" Margin="0,0,6,6"
                                Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVis}}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <TreeView ItemsSource="{Binding Roots}" BorderThickness="0" Background="Transparent"
                      SelectedItemChanged="Tree_SelectedItemChanged"
                      PreviewMouseRightButtonDown="Tree_PreviewMouseRightButtonDown"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <TreeView.Resources>
                    <!-- E4: 选中行用浅蓝高亮 + 深色文字, 避免系统深蓝把灰色"用途"文字吞掉看不清。 -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D6E6FB"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E7EEF8"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1A1A1A"/>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="Padding" Value="0,2"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Grid Margin="0,1">
                            <Grid.ContextMenu>
                                <!-- ContextMenu 不在同一可视树, 需经 PlacementTarget 取回行的 DataContext -->
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}"/>
                                    <!-- 删除后失效的"对实物的操作"整体隐藏 (定位/AI/迁移/回收) -->
                                    <MenuItem Header="复制用途 / 说明" Command="{Binding CopyPurposeCommand}"
                                              Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <MenuItem Header="在资源管理器中打开位置" Command="{Binding OpenLocationCommand}"
                                              Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <MenuItem Header="加入忽略名单" Command="{Binding AddIgnoreCommand}"
                                              Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <!-- 仅在已配置 AI 时出现; 点一次发一次脱敏请求, 识别这个目录是什么 (推测) -->
                                    <MenuItem Header="用 AI 识别用途 / 归属（推测）" Command="{Binding InvestigateCommand}"
                                              Visibility="{Binding ShowAiMenu, Converter={StaticResource BoolToVis}}"/>
                                    <Separator Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <MenuItem Header="迁移到其他盘（建目录联接，省 C 盘且软件照常用）" Command="{Binding MigrateCommand}"
                                              Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <MenuItem Header="移入回收站（可还原）" Command="{Binding RecycleCommand}"
                                              Visibility="{Binding ShowLiveActions, Converter={StaticResource BoolToVis}}"/>
                                    <!-- 问题#4: 高风险/识别不出的项 (如自己下载的文件夹), 强确认后手动移入回收站 -->
                                    <MenuItem Header="手动移入回收站（高风险项，需强确认）" Command="{Binding ManualRecycleCommand}"
                                              Visibility="{Binding CanManualRecycle, Converter={StaticResource BoolToVis}}"/>
                                    <!-- 删除后唯一可用动作 -->
                                    <MenuItem Header="在回收站中查看 / 还原" Command="{Binding OpenRecycleBinCommand}"
                                              Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVis}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 名称 + (批量勾选) + 四桶色点 + 文件/文件夹图标 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0"
                                          Visibility="{Binding CanSelect, Converter={StaticResource BoolToVis}}"/>
                                <Border Width="10" Height="10" CornerRadius="2" Margin="0,0,8,0"
                                        Background="{Binding BucketBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Glyph}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <!-- 已移入回收站: 删除线 + 置灰 -->
                                                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="  ✓可清理" Foreground="#1E7E34" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding IsCleanable, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="  ♻已移入回收站" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center"
                                           Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="  ✨AI推测" Foreground="#8451C4" FontSize="11" VerticalAlignment="Center"
                                           ToolTip="来源/用途由 AI 推测补充，仅供参考"
                                           Visibility="{Binding IsAiResolved, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="  ✨识别中…" Foreground="#8451C4" FontSize="11" VerticalAlignment="Center"
                                           FontStyle="Italic"
                                           Visibility="{Binding IsInvestigating, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <!-- 大小 + 占父目录比例条 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                <TextBlock Text="{Binding SizeText}" HorizontalAlignment="Right" FontFamily="Consolas"/>
                                <Border Height="4" CornerRadius="2" Background="#E6EAF0" Margin="0,2,0,0">
                                    <Border HorizontalAlignment="Left" CornerRadius="2" Background="{Binding BucketBrush}"
                                            Width="{Binding FractionOfParent, Converter={StaticResource FractionToWidth}, ConverterParameter=108}"/>
                                </Border>
                            </StackPanel>

                            <!-- 来源 = 安静的小 chip (用途/建议改由下方详情面板 + 悬停展示, 不再做常驻列, 去"表格感") -->
                            <Border Grid.Column="2" Style="{StaticResource Chip}" Background="{StaticResource Subtle}"
                                    Margin="10,0,0,0" ToolTip="{Binding Purpose}" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Origin}" FontSize="12" Foreground="{StaticResource Muted}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                            </Border>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>
    </Border>
</UserControl>
