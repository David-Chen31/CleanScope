<UserControl x:Class="CleanScope.App.Wpf.Controls.ToastHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{x:Null}" IsHitTestVisible="True">
    <ItemsControl x:Name="Items" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                  Margin="0,0,24,24">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Background="White" CornerRadius="10" Margin="0,8,0,0" MinWidth="280" MaxWidth="440"
                        Effect="{StaticResource PopShadow}" RenderTransformOrigin="1,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="t" X="24"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)"
                                                     From="0" To="1" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="t" Storyboard.TargetProperty="X"
                                                     From="24" To="0" Duration="0:0:0.14"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <DockPanel>
                        <Border Width="4" Background="{Binding AccentBrush}" DockPanel.Dock="Left" CornerRadius="10,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="14,11,14,11">
                            <TextBlock Text="{Binding Icon}" Foreground="{Binding AccentBrush}" FontWeight="Bold"
                                       FontSize="14" Margin="0,0,9,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource Ink}" TextWrapping="Wrap"
                                       MaxWidth="300" VerticalAlignment="Center"/>
                            <Button Content="{Binding ActionText}" Command="{Binding ActionCommand}"
                                    Style="{StaticResource Ghost}" Padding="9,4" Margin="12,0,0,0"
                                    Visibility="{Binding HasAction, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
