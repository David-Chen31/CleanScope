<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 浅色主题色板 (E: 与 Dark.xaml 同名键, 运行时整体替换即可切换主题) -->
    <!-- 底层 -->
    <SolidColorBrush x:Key="Bg"       Color="#F3F5F9"/>
    <SolidColorBrush x:Key="Card"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Subtle"   Color="#F4F6FA"/>
    <SolidColorBrush x:Key="Line"     Color="#E5E9F0"/>
    <SolidColorBrush x:Key="LineSoft" Color="#EEF1F6"/>
    <!-- 文字 -->
    <SolidColorBrush x:Key="Ink"      Color="#1A2230"/>
    <SolidColorBrush x:Key="Muted"    Color="#5C6877"/>
    <SolidColorBrush x:Key="Faint"    Color="#8A94A3"/>
    <!-- 强调 -->
    <SolidColorBrush x:Key="Accent"      Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentHover" Color="#1D4FD7"/>
    <SolidColorBrush x:Key="AccentPress" Color="#1A45BC"/>
    <SolidColorBrush x:Key="AccentSoft"  Color="#E8F0FE"/>
    <!-- 语义 (危险≠珍贵) -->
    <SolidColorBrush x:Key="Clean"        Color="#157347"/>
    <SolidColorBrush x:Key="CleanSoft"    Color="#E6F4EC"/>
    <SolidColorBrush x:Key="Personal"     Color="#3A6EA5"/>
    <SolidColorBrush x:Key="PersonalSoft" Color="#E8F0FA"/>
    <SolidColorBrush x:Key="Warn"         Color="#B7791F"/>
    <SolidColorBrush x:Key="WarnSoft"     Color="#FBF3E2"/>
    <SolidColorBrush x:Key="Critical"     Color="#C5221F"/>
    <SolidColorBrush x:Key="CriticalSoft" Color="#FBEAE9"/>
    <!-- 外壳 -->
    <SolidColorBrush x:Key="SidebarBg" Color="#FAFBFD"/>
    <SolidColorBrush x:Key="Hover"     Color="#EEF2F8"/>
    <!-- 中性轨道 / 软底 (进度条、比例条、状态条等浅底) -->
    <SolidColorBrush x:Key="Track"     Color="#E6EAF0"/>
    <!-- 首页 Hero 渐变端点 -->
    <SolidColorBrush x:Key="HeroTop"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeroBottom" Color="#F2F7FF"/>
    <!-- 输入控件底 (输入框/复选/单选/下拉的可填写底; 暗色用下沉井而非纯白, 避免亮块刺眼且文字反白) -->
    <SolidColorBrush x:Key="Input"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorderHover" Color="#C2CCDA"/>
    <!-- AI 推测语义紫 (脱敏推测标识; 暗色提亮以保证可读) -->
    <SolidColorBrush x:Key="Ai" Color="#8451C4"/>
    <!-- 风险等级配色 (空间地图 treemap + 图例共用; 暗色降饱和压暗与深色面板协调, 文字改 RiskInk) -->
    <SolidColorBrush x:Key="RiskA"         Color="#9BD3AE"/>
    <SolidColorBrush x:Key="RiskB"         Color="#A9C7F5"/>
    <SolidColorBrush x:Key="RiskC"         Color="#F4D58A"/>
    <SolidColorBrush x:Key="RiskD"         Color="#F0A8A4"/>
    <SolidColorBrush x:Key="RiskE"         Color="#C98B88"/>
    <SolidColorBrush x:Key="RiskNone"      Color="#C9D2DA"/>
    <SolidColorBrush x:Key="RiskRemainder" Color="#E6EAEE"/>
    <SolidColorBrush x:Key="RiskInk"       Color="#1F2933"/>
</ResourceDictionary>
